@tailwind base;
@tailwind components;
@tailwind utilities;

/* ══════════════════════════════════════════════════════════
   DESIGN TOKENS — El Remate Canelones · Mayorista Premium
   v1.0 — Paleta cálida, sistema de color por categoría
   ══════════════════════════════════════════════════════════ */
:root {
  /* Core Brand — Rojo Remate */
  --rojo: #D62828;
  --rojo-dark: #B01E1E;
  --rojo-pale: #FDF0F0;
  --rojo-glow: rgba(214, 40, 40, 0.22);

  /* Neutros Cálidos — Negro cálido + Crema */
  --oscuro: #1A1410;
  --oscuro-2: #2C2318;
  --oscuro-3: #3D3226;
  --crema: #F5F0E8;
  --crema-2: #EDE7DA;
  --crema-3: #E8DDD0;
  --white: #FFFFFF;

  /* Texto — sobre fondo claro */
  --texto: #1A1410;
  --tierra: #5C4A35;
  --muted: #9C8570;

  /* Bordes cálidos */
  --border: #E8DDD0;
  --border-2: #D4C5B0;
  --border2: var(--border-2);
  /* alias legacy */

  /* Acentos funcionales */
  --verde: #1A6B3C;
  --verde-dark: #145530;
  --verde-pale: #EBF5EE;
  --ambar: #D97706;
  --ambar-pale: #FEF3C7;

  /* Sombras — tono cálido */
  --shadow-sm: 0 1px 3px rgba(26, 20, 16, 0.08);
  --shadow-md: 0 4px 16px rgba(26, 20, 16, 0.1);
  --shadow-lg: 0 12px 40px rgba(26, 20, 16, 0.16);
  --shadow-panel: -8px 0 48px rgba(10, 8, 5, 0.28);

  /* Radius */
  --r-sm: 8px;
  --r-md: 12px;
  --r-lg: 16px;
  --r-xl: 20px;

  /* Tipografía */
  --font-display: var(--font-display, 'Bebas Neue', sans-serif);
  --font-serif: var(--font-serif, 'DM Serif Display', Georgia, serif);
  --font-body: var(--font-body, 'DM Sans', system-ui, sans-serif);
  --font-bebas: var(--font-display, 'Bebas Neue', sans-serif);

  /* Legacy alias for backward compat */
  --navy: var(--oscuro);
  --navy-deep: var(--oscuro);
  --navy-mid: var(--oscuro-2);
  --navy-light: var(--oscuro-3);
  --red: var(--rojo);
  --red-dark: var(--rojo-dark);
  --red-glow: var(--rojo-glow);
  --cyan: var(--rojo);
  --cyan-dark: var(--rojo-dark);
  --cyan-pale: var(--rojo-pale);
  --amber: var(--ambar);
  --amber-pale: var(--ambar-pale);
  --green: var(--verde);
  --green-dark: var(--verde-dark);

  /* Backgrounds (light mode default) */
  --bg: var(--crema);
  --bg2: var(--crema-2);
  --bg3: var(--crema-3);

  /* Text aliases */
  --text: var(--texto);
  --text2: var(--tierra);

  /* Colores por Categoría — 17 semánticos */
  --cat-aceites: #92400E;
  --cat-bebidas: #1D4ED8;
  --cat-cafe: #3B1C07;
  --cat-cereales: #D97706;
  --cat-congelados: #0369A1;
  --cat-pescado: #0F766E;
  --cat-descart: #6B7280;
  --cat-especias: #065F46;
  --cat-fiambres: #991B1B;
  --cat-golosinas: #7C3AED;
  --cat-harinas: #78350F;
  --cat-higiene: #0891B2;
  --cat-lacteos: #B45309;
  --cat-limpieza: #0E7490;
  --cat-mermeladas: #BE185D;
  --cat-otros: #6B7280;
  --cat-panaderia: #2A6B3E;
  --cat-papel: #475569;
}

/* DARK MODE — cálido, no frío */
.dark-mode {
  --bg: #0F0C08;
  --bg2: #1A1410;
  --bg3: #2C2318;
  --white: #1F1A14;

  --texto: #F0EBE3;
  --tierra: #B8A99A;
  --muted: #7A6F60;

  --border: #3D3226;
  --border-2: #4E4035;
  --border2: var(--border-2);
  /* alias legacy */

  --shadow-sm: 0 1px 3px rgba(0, 0, 0, 0.3);
  --shadow-md: 0 4px 16px rgba(0, 0, 0, 0.4);
  --shadow-lg: 0 12px 40px rgba(0, 0, 0, 0.5);
  --shadow-panel: -8px 0 48px rgba(0, 0, 0, 0.6);

  --text: var(--texto);
  --text2: var(--tierra);
}

/* ══════════════════════════════════════════════════════════
   BASE RESET & GLOBALS
   ══════════════════════════════════════════════════════════ */
*,
*::before,
*::after {
  box-sizing: border-box;
  margin: 0;
  padding: 0;
}

html {
  scroll-behavior: smooth;
}

body {
  font-family: var(--font-body), 'DM Sans', system-ui, -apple-system, sans-serif;
  background: var(--bg);
  color: var(--text);
  min-height: 100vh;
  -webkit-font-smoothing: antialiased;
  -moz-osx-font-smoothing: grayscale;
  transition: background 0.3s ease, color 0.3s ease;
}

html.dark-mode body {
  background: var(--bg);
}

/* Override all 'Inter' font-family references to use CSS variable */

/* ══════════════════════════════════════════════════════════
   HERO
   ══════════════════════════════════════════════════════════ */
.hero {
  background: var(--oscuro);
  position: relative;
  overflow: hidden;
}

.hero-bg-grid {
  position: absolute;
  inset: 0;
  background-image:
    linear-gradient(rgba(214, 201, 240, 0.04) 1px, transparent 1px),
    linear-gradient(90deg, rgba(214, 201, 240, 0.04) 1px, transparent 1px);
  background-size: 48px 48px;
  pointer-events: none;
}

.hero-bg-radial {
  position: absolute;
  inset: 0;
  background:
    radial-gradient(ellipse 60% 80% at -5% 50%, rgba(214, 40, 40, 0.22) 0%, transparent 55%),
    radial-gradient(ellipse 50% 60% at 105% 20%, rgba(214, 40, 40, 0.14) 0%, transparent 50%),
    radial-gradient(ellipse 40% 40% at 50% 110%, rgba(26, 20, 16, 0.9) 0%, transparent 60%);
  pointer-events: none;
}

.hero-stripe {
  position: absolute;
  top: -60px;
  right: -40px;
  width: 320px;
  height: 320px;
  background: linear-gradient(135deg, rgba(214, 40, 40, 0.06) 0%, transparent 60%);
  transform: rotate(-15deg);
  pointer-events: none;
}

.hero-inner {
  position: relative;
  z-index: 2;
  padding: 20px 20px 18px;
  display: flex;
  flex-direction: column;
  gap: 14px;
}

@media (min-width: 700px) {
  .hero-inner {
    flex-direction: row;
    align-items: center;
    justify-content: space-between;
    padding: 26px 32px 22px;
  }
}

/* Brand */
.hero-brand {
  display: flex;
  flex-direction: column;
  gap: 0;
}

.hero-eyebrow {
  display: inline-flex;
  align-items: center;
  gap: 7px;
  margin-bottom: 8px;
}

.hero-eyebrow-badge {
  background: var(--red);
  color: #fff;
  font-size: 0.58rem;
  font-weight: 700;
  letter-spacing: 2.5px;
  text-transform: uppercase;
  padding: 3px 10px;
  border-radius: 4px;
}

.hero-eyebrow-text {
  font-size: 0.65rem;
  font-weight: 600;
  letter-spacing: 3px;
  text-transform: uppercase;
  color: var(--rojo);
  opacity: 0.9;
}

.hero-title {
  font-family: var(--font-bebas), sans-serif;
  font-size: clamp(2.4rem, 7vw, 3.8rem);
  letter-spacing: 2.5px;
  line-height: 0.88;
  color: #fff;
}

.hero-title .accent {
  color: var(--rojo);
  display: block;
}

.hero-title .sub-accent {
  color: var(--red);
}

.hero-descriptor {
  margin-top: 10px;
  display: flex;
  align-items: center;
  gap: 8px;
  flex-wrap: wrap;
}

.hero-descriptor-line {
  width: 24px;
  height: 2px;
  background: var(--red);
  border-radius: 1px;
  flex-shrink: 0;
}

.hero-descriptor p {
  font-family: var(--font-serif), 'DM Serif Display', Georgia, serif;
  font-style: italic;
  font-size: 1rem;
  color: rgba(255, 255, 255, 0.85);
  font-weight: 400;
  letter-spacing: 0.2px;
  text-shadow: 0 1px 6px rgba(0, 0, 0, 0.4);
}

/* Stats strip */
.hero-stats {
  display: flex;
  gap: 0;
  margin-top: 16px;
  border: 1px solid rgba(214, 40, 40, 0.3);
  border-radius: var(--r-sm);
  overflow: hidden;
  width: fit-content;
}

.hero-stat {
  padding: 10px 18px;
  text-align: center;
  border-right: 1px solid rgba(214, 40, 40, 0.15);
}

.hero-stat:last-child {
  border-right: none;
}

.hero-stat-val {
  font-family: var(--font-display), 'Bebas Neue', sans-serif;
  font-size: 1.45rem;
  color: var(--rojo);
  letter-spacing: 1px;
  line-height: 1;
  text-shadow: 0 0 12px rgba(214, 40, 40, 0.3);
}

.hero-stat-lbl {
  font-size: 0.58rem;
  font-weight: 600;
  text-transform: uppercase;
  letter-spacing: 1px;
  color: rgba(255, 255, 255, 0.65);
  margin-top: 3px;
}

/* Right controls */
.hero-controls {
  display: flex;
  flex-direction: column;
  gap: 8px;
  width: 100%;
}

@media (min-width: 700px) {
  .hero-controls {
    width: 300px;
    flex-shrink: 0;
  }
}

/* Search */
.hero-search-wrap {
  position: relative;
}

.hero-search-wrap input {
  width: 100%;
  padding: 12px 16px 12px 44px;
  border-radius: var(--r-md);
  border: 1px solid rgba(255, 255, 255, 0.25);
  background: rgba(255, 255, 255, 0.12);
  backdrop-filter: blur(8px);
  color: #fff;
  font-family: var(--font-body), 'DM Sans', sans-serif;
  font-size: 0.9rem;
  font-weight: 500;
  outline: none;
  transition: all 0.2s;
  box-shadow: 0 2px 12px rgba(0, 0, 0, 0.2);
}

.hero-search-wrap input::placeholder {
  color: rgba(255, 255, 255, 0.5);
  font-weight: 400;
}

.hero-search-wrap input:focus {
  background: rgba(255, 255, 255, 0.18);
  border-color: rgba(214, 40, 40, 0.5);
  box-shadow: 0 0 0 3px rgba(214, 40, 40, 0.15), 0 4px 16px rgba(0, 0, 0, 0.3);
}

.hero-search-icon {
  position: absolute;
  left: 14px;
  top: 50%;
  transform: translateY(-50%);
  font-size: 0.95rem;
  color: rgba(255, 255, 255, 0.5);
  pointer-events: none;
}

/* CTA row */
.hero-actions {
  display: flex;
  gap: 7px;
}

.btn-hero-cart {
  flex: 1;
  background: var(--rojo);
  color: #fff;
  border: none;
  border-radius: var(--r-md);
  padding: 11px 16px;
  font-family: var(--font-display), 'Bebas Neue', sans-serif;
  font-size: 1.05rem;
  letter-spacing: 1.5px;
  cursor: pointer;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8px;
  transition: all 0.15s;
  box-shadow: 0 4px 18px var(--rojo-glow);
  white-space: nowrap;
  position: relative;
  overflow: hidden;
}

.btn-hero-cart::after {
  content: '';
  position: absolute;
  inset: 0;
  background: linear-gradient(135deg, rgba(255, 255, 255, 0.1) 0%, transparent 60%);
  pointer-events: none;
}

.btn-hero-cart:hover {
  background: var(--rojo-dark);
  transform: translateY(-1px);
  box-shadow: 0 6px 22px var(--rojo-glow);
}

.cart-badge {
  background: rgba(0, 0, 0, 0.25);
  color: #fff;
  border-radius: 50%;
  min-width: 19px;
  height: 19px;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  font-size: 0.65rem;
  font-weight: 700;
  font-family: var(--font-body), 'DM Sans', sans-serif;
  padding: 0 4px;
}

.hero-total-pill {
  background: rgba(0, 0, 0, 0.2);
  border-radius: 5px;
  padding: 1px 8px;
  font-family: var(--font-body), 'DM Sans', sans-serif;
  font-size: 0.8rem;
  font-weight: 800;
}

/* Share cart button */
.btn-hero-share {
  background: rgba(214, 40, 40, 0.1);
  border: 1.5px solid rgba(214, 40, 40, 0.3);
  color: var(--rojo);
  border-radius: var(--r-md);
  width: 42px;
  height: 42px;
  display: flex;
  align-items: center;
  justify-content: center;
  cursor: pointer;
  font-size: 1rem;
  transition: all 0.15s;
  flex-shrink: 0;
  position: relative;
}

.btn-hero-share:hover {
  background: rgba(214, 40, 40, 0.18);
  border-color: rgba(214, 40, 40, 0.55);
}

.btn-hero-share .share-tooltip {
  position: absolute;
  bottom: calc(100% + 8px);
  right: 0;
  background: var(--oscuro);
  color: #fff;
  font-family: var(--font-body), 'DM Sans', sans-serif;
  font-size: 0.65rem;
  font-weight: 600;
  white-space: nowrap;
  padding: 4px 9px;
  border-radius: 6px;
  border: 1px solid rgba(214, 40, 40, 0.2);
  opacity: 0;
  pointer-events: none;
  transition: opacity 0.15s;
}

.btn-hero-share:hover .share-tooltip {
  opacity: 1;
}

/* User btn */
.btn-hero-user {
  background: rgba(255, 255, 255, 0.07);
  border: 1.5px solid rgba(255, 255, 255, 0.1);
  color: rgba(255, 255, 255, 0.75);
  border-radius: var(--r-md);
  width: 42px;
  height: 42px;
  display: flex;
  align-items: center;
  justify-content: center;
  cursor: pointer;
  font-size: 1.1rem;
  transition: all 0.15s;
  flex-shrink: 0;
  position: relative;
}

.btn-hero-user:hover {
  background: rgba(255, 255, 255, 0.14);
  color: #fff;
}

.btn-hero-user.logged-in {
  background: rgba(26, 107, 60, 0.12);
  border-color: rgba(26, 107, 60, 0.35);
  color: var(--verde);
}

.user-dot {
  position: absolute;
  bottom: 5px;
  right: 5px;
  width: 7px;
  height: 7px;
  background: var(--verde);
  border-radius: 50%;
  border: 1.5px solid var(--oscuro);
  display: none;
}

.btn-hero-user.logged-in .user-dot {
  display: block;
}

/* ══════════════════════════════════════════════════════════
   TICKER
   ══════════════════════════════════════════════════════════ */
.ticker {
  background: var(--oscuro-2);
  border-top: 1px solid rgba(214, 40, 40, 0.12);
  border-bottom: 1px solid rgba(214, 40, 40, 0.12);
  overflow: hidden;
  padding: 8px 0;
}

.ticker-track {
  display: flex;
  animation: tickerScroll 32s linear infinite;
  white-space: nowrap;
}

.ticker-item {
  font-size: 0.68rem;
  font-weight: 600;
  letter-spacing: 1.5px;
  text-transform: uppercase;
  color: var(--crema);
  opacity: 0.55;
  padding: 0 28px;
  flex-shrink: 0;
}

.ticker-item .sep {
  color: var(--rojo);
  margin: 0 4px;
  opacity: 1;
}

@keyframes tickerScroll {
  0% {
    transform: translateX(0);
  }

  100% {
    transform: translateX(-50%);
  }
}

/* ══════════════════════════════════════════════════════════
   STICKY NAV — Category pills
   ══════════════════════════════════════════════════════════ */
.sticky-nav {
  background: var(--white);
  border-bottom: 1.5px solid var(--border);
  position: sticky;
  top: 0;
  z-index: 90;
  box-shadow: 0 2px 16px rgba(26, 20, 16, 0.06);
}

.cats-wrap {
  overflow-x: auto;
  -webkit-overflow-scrolling: touch;
  scrollbar-width: none;
  padding: 0 12px;
}

.cats-wrap::-webkit-scrollbar {
  display: none;
}

.cats-inner {
  display: inline-flex;
  gap: 5px;
  padding: 8px 4px;
}

.cat-pill {
  display: inline-block;
  padding: 5px 13px;
  border-radius: var(--r-sm);
  font-size: 0.74rem;
  font-weight: 600;
  cursor: pointer;
  border: 1.5px solid transparent;
  background: var(--bg2);
  color: var(--text2);
  transition: all 0.13s;
  white-space: nowrap;
  user-select: none;
}

.cat-pill:hover {
  background: var(--bg3);
  color: var(--text);
}

.cat-pill.active {
  background: var(--oscuro);
  color: #fff;
  border-color: rgba(214, 40, 40, 0.35);
  box-shadow: 0 2px 8px rgba(26, 20, 16, 0.2), 0 0 0 1px rgba(214, 40, 40, 0.15);
}

/* ══════════════════════════════════════════════════════════
   RESULTS BAR
   ══════════════════════════════════════════════════════════ */
.results-bar {
  padding: 10px 16px 2px;
  font-size: 0.74rem;
  color: var(--muted);
  font-weight: 500;
  display: flex;
  align-items: center;
  justify-content: space-between;
  flex-wrap: wrap;
  gap: 8px;
}

.view-toggle {
  display: inline-flex;
  border: 1.5px solid var(--border);
  border-radius: var(--r-sm);
  overflow: hidden;
}

.view-toggle button {
  background: var(--bg2);
  border: none;
  padding: 5px 12px;
  font-size: 0.72rem;
  font-weight: 600;
  font-family: var(--font-body), 'DM Sans', sans-serif;
  color: var(--text2);
  cursor: pointer;
  transition: all 0.13s;
}

.view-toggle button+button {
  border-left: 1.5px solid var(--border);
}

.view-toggle button.active {
  background: var(--oscuro);
  color: #fff;
}

/* ══════════════════════════════════════════════════════════
   PRODUCT GRID
   ══════════════════════════════════════════════════════════ */
.grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 10px;
  padding: 8px 12px 20px;
}

@media (min-width: 520px) {
  .grid {
    grid-template-columns: repeat(3, 1fr);
  }
}

@media (min-width: 780px) {
  .grid {
    grid-template-columns: repeat(4, 1fr);
  }
}

@media (min-width: 1060px) {
  .grid {
    grid-template-columns: repeat(5, 1fr);
  }
}

@media (min-width: 1300px) {
  .grid {
    grid-template-columns: repeat(6, 1fr);
  }
}

/* Card */
.card {
  background: var(--white);
  border-radius: var(--r-lg);
  border: 1.5px solid var(--border);
  border-top: 3px solid var(--cat-color, var(--border));
  display: flex;
  flex-direction: column;
  overflow: hidden;
  transition: box-shadow 0.18s, transform 0.15s, border-color 0.15s;
  position: relative;
  animation: cardFadeIn 0.28s ease both;
}

.card:hover {
  box-shadow: var(--shadow-md);
  transform: translateY(-2px);
  border-color: var(--border2);
}

.card.in-cart {
  border-color: rgba(26, 107, 60, 0.45);
  box-shadow: 0 0 0 1px rgba(26, 107, 60, 0.12);
}

@keyframes cardFadeIn {
  from {
    opacity: 0;
    transform: translateY(8px);
  }

  to {
    opacity: 1;
    transform: translateY(0);
  }
}

@keyframes cardPop {
  0% {
    transform: scale(1);
  }

  45% {
    transform: scale(1.05);
  }

  100% {
    transform: scale(1);
  }
}

.card.popped {
  animation: cardPop 0.22s ease-out;
}

.card-thumb {
  background: linear-gradient(145deg, var(--bg) 0%, var(--bg2) 100%);
  height: 76px;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 2rem;
  flex-shrink: 0;
  position: relative;
}

.card.in-cart .card-thumb::after {
  content: '\2713';
  position: absolute;
  top: 6px;
  right: 6px;
  background: var(--verde);
  color: #fff;
  width: 18px;
  height: 18px;
  border-radius: 50%;
  font-size: 0.62rem;
  font-weight: 800;
  display: flex;
  align-items: center;
  justify-content: center;
}

.cat-badge {
  position: absolute;
  top: 6px;
  left: 6px;
  background: rgba(26, 20, 16, 0.65);
  backdrop-filter: blur(4px);
  color: rgba(255, 255, 255, 0.85);
  font-size: 0.5rem;
  padding: 2px 6px;
  border-radius: 5px;
  font-weight: 600;
  text-transform: uppercase;
  letter-spacing: 0.5px;
  max-width: 88px;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.card-body {
  padding: 9px 10px 10px;
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 4px;
}

.card-name {
  font-size: 0.7rem;
  font-weight: 700;
  line-height: 1.28;
  color: var(--text);
  text-transform: uppercase;
  letter-spacing: 0.15px;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.card-price {
  font-family: var(--font-display), 'Bebas Neue', sans-serif;
  font-size: 1.5rem;
  color: var(--texto);
  letter-spacing: 0.5px;
  line-height: 1;
}

.card-price-label {
  font-size: 0.57rem;
  color: var(--muted);
  font-weight: 500;
  text-transform: uppercase;
  letter-spacing: 0.4px;
  margin-top: -3px;
}

.card-actions {
  display: flex;
  align-items: center;
  gap: 5px;
  margin-top: auto;
  padding-top: 6px;
}

.btn-add {
  flex: 1;
  background: var(--oscuro);
  color: #fff;
  border: none;
  border-radius: var(--r-sm);
  padding: 8px 4px;
  font-family: var(--font-body), 'DM Sans', sans-serif;
  font-size: 0.71rem;
  font-weight: 700;
  cursor: pointer;
  text-align: center;
  transition: background 0.13s, transform 0.1s;
}

.btn-add:hover {
  background: var(--oscuro-2);
  transform: scale(1.02);
}

.qty-ctrl {
  display: flex;
  align-items: center;
  gap: 3px;
  width: 100%;
  background: var(--bg2);
  border-radius: var(--r-sm);
  padding: 3px;
}

.qty-btn {
  background: var(--white);
  border: 1.5px solid var(--border);
  border-radius: 6px;
  min-width: 44px;
  min-height: 44px;
  display: flex;
  align-items: center;
  justify-content: center;
  cursor: pointer;
  font-size: 1rem;
  font-weight: 700;
  color: var(--texto);
  transition: background 0.1s, border-color 0.1s;
  flex-shrink: 0;
}

.qty-btn:hover {
  background: var(--rojo-pale);
  border-color: var(--rojo-dark);
  color: var(--rojo);
}

.qty-val {
  flex: 1;
  text-align: center;
  font-weight: 800;
  font-size: 0.88rem;
  color: var(--text);
}

/* ══════════════════════════════════════════════════════════
   PRODUCT LIST (ROW MODE)
   ══════════════════════════════════════════════════════════ */
.product-list {
  display: flex;
  flex-direction: column;
  gap: 8px;
  padding: 8px 12px 20px;
}

.product-row {
  background: var(--white);
  border: 1.5px solid var(--border);
  border-radius: var(--r-md);
  display: flex;
  align-items: center;
  gap: 12px;
  padding: 10px 12px;
  transition: box-shadow 0.18s, transform 0.15s, border-color 0.15s;
  animation: cardFadeIn 0.28s ease both;
}

.product-row:hover {
  box-shadow: var(--shadow-sm);
  border-color: var(--border2);
}

.product-row.in-cart {
  border-color: rgba(26, 107, 60, 0.45);
  box-shadow: 0 0 0 1px rgba(26, 107, 60, 0.12);
}

.row-thumb {
  width: 48px;
  height: 48px;
  background: linear-gradient(145deg, var(--bg) 0%, var(--bg2) 100%);
  border-radius: var(--r-sm);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 1.4rem;
  flex-shrink: 0;
  position: relative;
}

.product-row.in-cart .row-thumb::after {
  content: '\2713';
  position: absolute;
  top: -4px;
  right: -4px;
  background: var(--verde);
  color: #fff;
  width: 16px;
  height: 16px;
  border-radius: 50%;
  font-size: 0.55rem;
  font-weight: 800;
  display: flex;
  align-items: center;
  justify-content: center;
}

.row-info {
  flex: 1;
  min-width: 0;
}

.row-name {
  font-size: 0.78rem;
  font-weight: 700;
  text-transform: uppercase;
  color: var(--text);
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.row-price {
  font-family: var(--font-display), 'Bebas Neue', sans-serif;
  font-size: 1.25rem;
  color: var(--texto);
  letter-spacing: 0.5px;
  line-height: 1.1;
}

.row-price-label {
  font-size: 0.55rem;
  color: var(--muted);
  font-weight: 500;
  text-transform: uppercase;
  letter-spacing: 0.4px;
}

.row-actions {
  flex-shrink: 0;
  display: flex;
  align-items: center;
}

/* ══════════════════════════════════════════════════════════
   MAS PEDIDOS — Horizontal scrollable section
   ══════════════════════════════════════════════════════════ */
.mas-pedidos-section {
  background: var(--amber-pale);
  border-top: 2px solid rgba(248, 150, 30, 0.2);
  border-bottom: 2px solid rgba(248, 150, 30, 0.2);
}

.mas-pedidos {
  padding: 16px 0 8px;
}

.mas-pedidos-header {
  padding: 0 16px 10px;
  display: flex;
  align-items: center;
  gap: 8px;
}

.mas-pedidos-header .fire {
  font-size: 1.2rem;
}

.mas-pedidos-badge {
  background: var(--ambar);
  color: #fff;
  font-size: 0.55rem;
  font-weight: 700;
  padding: 2px 8px;
  border-radius: 4px;
  text-transform: uppercase;
  letter-spacing: 1px;
  margin-left: 8px;
}

.mas-pedidos-title {
  font-family: var(--font-display), 'Bebas Neue', sans-serif;
  font-size: 1.3rem;
  letter-spacing: 1px;
  color: var(--texto);
  display: flex;
  align-items: center;
}

.mas-pedidos-scroll {
  display: flex;
  gap: 10px;
  overflow-x: auto;
  -webkit-overflow-scrolling: touch;
  scrollbar-width: none;
  padding: 0 12px 8px;
}

.mas-pedidos-scroll::-webkit-scrollbar {
  display: none;
}

.mas-pedido-card {
  flex-shrink: 0;
  width: 160px;
  background: var(--white);
  border: 1.5px solid var(--ambar-pale);
  border-radius: var(--r-md);
  overflow: hidden;
  transition: transform 0.15s, box-shadow 0.15s;
  animation: cardFadeIn 0.3s ease both;
}

.mas-pedido-card:hover {
  transform: translateY(-2px);
  box-shadow: var(--shadow-md);
}

.mas-pedido-thumb {
  background: linear-gradient(145deg, var(--ambar-pale) 0%, var(--bg2) 100%);
  height: 64px;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 1.8rem;
  position: relative;
}

.mas-pedido-rank {
  position: absolute;
  top: 4px;
  left: 4px;
  background: var(--ambar);
  color: #fff;
  width: 18px;
  height: 18px;
  border-radius: 50%;
  font-size: 0.55rem;
  font-weight: 800;
  display: flex;
  align-items: center;
  justify-content: center;
  font-family: var(--font-body), 'DM Sans', sans-serif;
}

.mas-pedido-body {
  padding: 8px 8px 10px;
}

.mas-pedido-name {
  font-size: 0.65rem;
  font-weight: 700;
  text-transform: uppercase;
  color: var(--text);
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
  line-height: 1.25;
}

.mas-pedido-price {
  font-family: var(--font-display), 'Bebas Neue', sans-serif;
  font-size: 1.2rem;
  color: var(--texto);
  line-height: 1;
  margin-top: 2px;
}

/* ══════════════════════════════════════════════════════════
   LOAD MORE
   ══════════════════════════════════════════════════════════ */
.load-more-wrap {
  text-align: center;
  padding: 16px;
}

.btn-load-more {
  background: transparent;
  color: var(--oscuro);
  border: 2px solid var(--oscuro);
  border-radius: 10px;
  padding: 10px 28px;
  font-family: var(--font-display), 'Bebas Neue', sans-serif;
  font-size: 1.1rem;
  letter-spacing: 1px;
  cursor: pointer;
  transition: all 0.15s;
}

.btn-load-more:hover {
  background: var(--oscuro);
  color: #fff;
}

/* ══════════════════════════════════════════════════════════
   EMPTY STATE
   ══════════════════════════════════════════════════════════ */
.no-results {
  text-align: center;
  padding: 70px 20px;
  color: var(--muted);
}

.no-results-icon {
  font-size: 2.8rem;
  margin-bottom: 12px;
  opacity: 0.45;
  display: block;
}

/* ══════════════════════════════════════════════════════════
   FLOAT CART
   ══════════════════════════════════════════════════════════ */
.float-cart {
  position: fixed;
  bottom: 20px;
  left: 50%;
  transform: translateX(-50%) translateY(80px);
  background: var(--oscuro);
  color: #fff;
  border: 1.5px solid rgba(214, 40, 40, 0.2);
  border-radius: 30px;
  padding: 12px 20px;
  font-family: var(--font-display), 'Bebas Neue', sans-serif;
  font-size: 1.05rem;
  letter-spacing: 1.5px;
  cursor: pointer;
  display: flex;
  align-items: center;
  gap: 10px;
  box-shadow: 0 8px 32px rgba(10, 8, 5, 0.4);
  z-index: 89;
  transition: transform 0.3s cubic-bezier(.34, 1.56, .64, 1), box-shadow 0.2s;
  white-space: nowrap;
  opacity: 0;
}

.float-cart.has-items {
  transform: translateX(-50%) translateY(0);
  opacity: 1;
}

.float-cart:hover {
  box-shadow: 0 12px 40px rgba(10, 8, 5, 0.5);
}

.float-qty {
  background: var(--rojo);
  color: #fff;
  border-radius: 50%;
  width: 20px;
  height: 20px;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 0.65rem;
  font-family: var(--font-body), 'DM Sans', sans-serif;
  font-weight: 700;
}

.float-total {
  background: rgba(214, 40, 40, 0.15);
  border: 1px solid rgba(214, 40, 40, 0.3);
  color: var(--rojo);
  border-radius: 10px;
  padding: 2px 10px;
  font-size: 0.95rem;
  font-weight: 800;
  font-family: var(--font-body), 'DM Sans', sans-serif;
}

/* ══════════════════════════════════════════════════════════
   CART PANEL — Additional styles
   ══════════════════════════════════════════════════════════ */
.cart-note-toggle {
  background: none;
  border: none;
  font-size: 0.62rem;
  font-weight: 600;
  color: var(--muted);
  cursor: pointer;
  padding: 2px 0;
  margin-top: 3px;
  font-family: var(--font-body), 'DM Sans', sans-serif;
  transition: color 0.12s;
}

.cart-note-toggle:hover {
  color: var(--text2);
}

.cart-note-input {
  margin-top: 4px;
  padding: 7px 10px;
  font-size: 0.72rem;
}

.cart-item-remove {
  background: none;
  border: none;
  color: var(--muted);
  cursor: pointer;
  width: 24px;
  height: 24px;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
  font-size: 0.85rem;
  transition: all 0.12s;
  flex-shrink: 0;
}

.cart-item-remove:hover {
  background: var(--rojo-pale);
  color: var(--rojo);
}

.btn-save-lista {
  width: 100%;
  background: var(--bg2);
  border: 1.5px solid var(--border);
  color: var(--text2);
  border-radius: var(--r-sm);
  padding: 9px 16px;
  font-family: var(--font-body), 'DM Sans', sans-serif;
  font-size: 0.78rem;
  font-weight: 700;
  cursor: pointer;
  transition: all 0.13s;
  margin-bottom: 10px;
  text-align: center;
}

.btn-save-lista:hover {
  background: var(--bg3);
  border-color: var(--border2);
}

.btn-clear-cart {
  width: 100%;
  background: transparent;
  border: 1.5px solid var(--border2);
  color: var(--muted);
  border-radius: var(--r-sm);
  padding: 9px 16px;
  font-family: var(--font-body), 'DM Sans', sans-serif;
  font-size: 0.78rem;
  font-weight: 600;
  cursor: pointer;
  transition: all 0.13s;
}

.btn-clear-cart:hover {
  border-color: var(--rojo);
  color: var(--rojo);
  background: var(--rojo-pale);
}

/* ══════════════════════════════════════════════════════════
   CONFIRM MODAL
   ══════════════════════════════════════════════════════════ */
.confirm-modal-overlay {
  position: fixed;
  inset: 0;
  background: rgba(10, 8, 5, 0.75);
  backdrop-filter: blur(4px);
  z-index: 300;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 20px;
  animation: fadeIn 0.15s ease;
}

@keyframes fadeIn {
  from {
    opacity: 0;
  }

  to {
    opacity: 1;
  }
}

.confirm-modal-box {
  background: var(--white);
  border-radius: var(--r-lg);
  width: 100%;
  max-width: 400px;
  box-shadow: var(--shadow-lg);
  animation: modalSlide 0.2s ease;
}

@keyframes modalSlide {
  from {
    opacity: 0;
    transform: translateY(16px) scale(0.97);
  }

  to {
    opacity: 1;
    transform: translateY(0) scale(1);
  }
}

.confirm-modal-header {
  background: var(--oscuro);
  padding: 20px 20px 14px;
  border-radius: var(--r-lg) var(--r-lg) 0 0;
  text-align: center;
  position: relative;
  overflow: hidden;
}

.confirm-modal-header::before {
  content: '';
  position: absolute;
  inset: 0;
  background-image:
    linear-gradient(rgba(214, 40, 40, 0.05) 1px, transparent 1px),
    linear-gradient(90deg, rgba(214, 40, 40, 0.05) 1px, transparent 1px);
  background-size: 32px 32px;
  pointer-events: none;
}

.confirm-modal-emoji {
  font-size: 2rem;
  display: block;
  margin-bottom: 6px;
  position: relative;
  z-index: 1;
}

.confirm-modal-title {
  font-family: var(--font-display), 'Bebas Neue', sans-serif;
  font-size: 1.6rem;
  color: #fff;
  letter-spacing: 1px;
  position: relative;
  z-index: 1;
}

.confirm-modal-summary {
  display: flex;
  justify-content: center;
  align-items: baseline;
  gap: 10px;
  padding: 14px 20px 0;
  border-bottom: 1.5px solid var(--border);
}

.confirm-modal-count {
  font-size: 0.82rem;
  font-weight: 700;
  color: var(--text2);
  text-transform: uppercase;
  letter-spacing: 0.5px;
}

.confirm-modal-total {
  font-family: var(--font-display), 'Bebas Neue', sans-serif;
  font-size: 1.5rem;
  color: var(--texto);
  letter-spacing: 0.5px;
}

.confirm-modal-items {
  padding: 10px 20px;
  list-style: none;
  display: flex;
  flex-direction: column;
  gap: 6px;
}

.confirm-modal-item {
  display: flex;
  align-items: center;
  gap: 8px;
  font-size: 0.75rem;
  padding: 6px 0;
  border-bottom: 1px solid var(--bg2);
}

.confirm-modal-item:last-child {
  border-bottom: none;
}

.confirm-modal-item-qty {
  font-weight: 800;
  color: var(--rojo-dark);
  min-width: 28px;
}

.confirm-modal-item-name {
  flex: 1;
  font-weight: 600;
  color: var(--text);
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.confirm-modal-item-subtotal {
  font-weight: 700;
  color: var(--text2);
  flex-shrink: 0;
}

.confirm-modal-more {
  font-size: 0.74rem;
  font-weight: 600;
  color: var(--muted);
  text-align: center;
  padding: 4px 0;
}

.confirm-modal-actions {
  padding: 14px 20px 18px;
  display: flex;
  flex-direction: column;
  gap: 8px;
}

.btn-continue-shopping {
  background: transparent;
  border: 1.5px solid var(--border2);
  color: var(--text2);
  border-radius: var(--r-md);
  padding: 11px 20px;
  font-family: var(--font-body), 'DM Sans', sans-serif;
  font-size: 0.85rem;
  font-weight: 700;
  cursor: pointer;
  transition: all 0.13s;
}

.btn-continue-shopping:hover {
  border-color: var(--oscuro);
  color: var(--oscuro);
  background: var(--bg2);
}

.btn-confirm-send {
  background: var(--verde);
  color: #fff;
  border: none;
  border-radius: var(--r-md);
  padding: 13px 20px;
  font-family: var(--font-display), 'Bebas Neue', sans-serif;
  font-size: 1.1rem;
  letter-spacing: 1px;
  cursor: pointer;
  transition: all 0.13s;
  box-shadow: 0 4px 18px rgba(26, 107, 60, 0.3);
}

.btn-confirm-send:hover {
  background: var(--verde-dark);
  transform: scale(1.01);
}

@media (max-width: 420px) {
  .confirm-modal-overlay {
    padding: 12px;
  }

  .confirm-modal-box {
    max-width: 100%;
  }
}

/* ══════════════════════════════════════════════════════════
   OVERLAY
   ══════════════════════════════════════════════════════════ */
.overlay {
  display: none;
  position: fixed;
  inset: 0;
  background: rgba(10, 8, 5, 0.75);
  z-index: 200;
  backdrop-filter: blur(4px);
}

.overlay.open {
  display: block;
}

/* ══════════════════════════════════════════════════════════
   SIDE PANEL BASE
   ══════════════════════════════════════════════════════════ */
.side-panel {
  position: fixed;
  top: 0;
  bottom: 0;
  width: 100%;
  max-width: 440px;
  background: var(--white);
  z-index: 201;
  display: flex;
  flex-direction: column;
  transition: transform 0.32s cubic-bezier(0.4, 0, 0.2, 1);
  box-shadow: var(--shadow-panel);
}

.side-panel.right {
  right: 0;
  transform: translateX(100%);
}

.side-panel.right.open {
  transform: translateX(0);
}

.side-panel.left {
  left: 0;
  transform: translateX(-100%);
}

.side-panel.left.open {
  transform: translateX(0);
}

/* Panel header dark */
.panel-header-dark {
  background: var(--oscuro);
  padding: 20px 20px 16px;
  position: relative;
  overflow: hidden;
  flex-shrink: 0;
}

.panel-header-dark::before {
  content: "";
  position: absolute;
  inset: 0;
  background-image:
    linear-gradient(rgba(214, 40, 40, 0.05) 1px, transparent 1px),
    linear-gradient(90deg, rgba(214, 40, 40, 0.05) 1px, transparent 1px);
  background-size: 32px 32px;
  pointer-events: none;
}

.panel-header-inner {
  position: relative;
  z-index: 1;
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
}

.panel-header-brand {
  display: flex;
  flex-direction: column;
  gap: 1px;
}

.panel-eyebrow {
  font-size: 0.58rem;
  font-weight: 600;
  letter-spacing: 3px;
  text-transform: uppercase;
  color: var(--rojo);
  opacity: 0.8;
}

.panel-title {
  font-family: var(--font-display), 'Bebas Neue', sans-serif;
  font-size: 1.85rem;
  letter-spacing: 1.5px;
  line-height: 1;
  color: #fff;
}

.panel-sub {
  font-family: var(--font-serif), 'DM Serif Display', Georgia, serif;
  font-style: italic;
  font-size: 0.82rem;
  color: rgba(255, 255, 255, 0.4);
  margin-top: 4px;
  font-weight: 400;
}

.panel-close {
  background: rgba(255, 255, 255, 0.08);
  border: 1px solid rgba(255, 255, 255, 0.12);
  color: rgba(255, 255, 255, 0.7);
  border-radius: var(--r-sm);
  width: 34px;
  height: 34px;
  cursor: pointer;
  font-size: 1rem;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: all 0.12s;
  flex-shrink: 0;
}

.panel-close:hover {
  background: rgba(255, 255, 255, 0.16);
  color: #fff;
}

/* ══════════════════════════════════════════════════════════
   CART PANEL
   ══════════════════════════════════════════════════════════ */
.cart-items {
  flex: 1;
  overflow-y: auto;
  padding: 12px 12px 4px;
  display: flex;
  flex-direction: column;
  gap: 7px;
}

.cart-empty {
  text-align: center;
  color: var(--muted);
  padding: 50px 20px;
}

.cart-empty-icon {
  font-size: 3rem;
  margin-bottom: 12px;
  display: block;
  opacity: 0.4;
}

.cart-empty strong {
  color: var(--text2);
  font-size: 0.95rem;
  display: block;
  margin-bottom: 4px;
}

.cart-empty p {
  font-size: 0.78rem;
}

.cart-item {
  background: var(--bg);
  border: 1.5px solid var(--border);
  border-radius: var(--r-md);
  padding: 9px 11px;
  display: flex;
  align-items: center;
  gap: 9px;
  transition: border-color 0.13s;
}

.cart-item:hover {
  border-color: var(--border2);
}

.cart-item-icon {
  font-size: 1.4rem;
  flex-shrink: 0;
}

.cart-item-info {
  flex: 1;
  min-width: 0;
}

.cart-item-name {
  font-size: 0.7rem;
  font-weight: 700;
  text-transform: uppercase;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
  color: var(--text);
}

.cart-item-subtotal {
  font-family: var(--font-display), 'Bebas Neue', sans-serif;
  font-size: 1.05rem;
  color: var(--texto);
  letter-spacing: 0.5px;
  margin-top: 1px;
}

.cart-item-qty {
  display: flex;
  align-items: center;
  gap: 5px;
  flex-shrink: 0;
}

.cart-item-qty .qty-btn {
  min-width: 44px;
  min-height: 44px;
}

.cart-item-qty .qty-val {
  width: 22px;
  font-size: 0.85rem;
}

/* Cart footer */
.cart-footer {
  border-top: 1.5px solid var(--border);
  flex-shrink: 0;
}

.cart-total-section {
  padding: 12px 16px 10px;
  background: var(--bg);
  border-bottom: 1.5px solid var(--border);
}

.cart-total-row {
  display: flex;
  justify-content: space-between;
  align-items: baseline;
}

.cart-total-label {
  font-size: 0.74rem;
  font-weight: 600;
  color: var(--muted);
  text-transform: uppercase;
  letter-spacing: 1px;
}

.cart-total-amount {
  font-family: var(--font-display), 'Bebas Neue', sans-serif;
  font-size: 2.1rem;
  color: var(--texto);
  letter-spacing: 1px;
}

.cart-disclaimer {
  font-family: var(--font-serif), 'DM Serif Display', Georgia, serif;
  font-style: italic;
  font-size: 0.72rem;
  color: var(--muted);
  margin-top: 3px;
}

.cart-order-section {
  padding: 14px 16px 16px;
}

.cart-share-section {
  padding: 10px 16px 0;
  border-bottom: 1.5px solid var(--border);
}

.cart-section-title {
  font-size: 0.68rem;
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: 1.5px;
  color: var(--muted);
  margin-bottom: 10px;
}

.field-label {
  display: block;
  font-size: 0.68rem;
  font-weight: 600;
  text-transform: uppercase;
  letter-spacing: 0.5px;
  color: var(--text2);
  margin-bottom: 5px;
}

.field-input {
  width: 100%;
  padding: 10px 12px;
  border: 1.5px solid var(--border);
  border-radius: var(--r-sm);
  font-family: var(--font-body), 'DM Sans', sans-serif;
  font-size: 0.9rem;
  outline: none;
  transition: border 0.15s;
  color: var(--text);
  background: var(--bg);
  margin-bottom: 10px;
}

.field-input:focus {
  border-color: var(--rojo-dark);
  background: var(--white);
}

.field-input::placeholder {
  color: var(--muted);
}

.btn-share-cart {
  width: 100%;
  background: var(--rojo-pale);
  border: 1.5px solid rgba(214, 40, 40, 0.35);
  color: var(--rojo-dark);
  border-radius: var(--r-md);
  padding: 10px 16px;
  font-family: var(--font-body), 'DM Sans', sans-serif;
  font-size: 0.82rem;
  font-weight: 700;
  cursor: pointer;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8px;
  transition: all 0.15s;
  margin-bottom: 10px;
}

.btn-share-cart:hover {
  background: rgba(214, 40, 40, 0.2);
  border-color: rgba(214, 40, 40, 0.55);
}

.share-link-row {
  display: flex;
  gap: 6px;
  align-items: center;
  margin-bottom: 10px;
}

.share-link-input {
  flex: 1;
  padding: 8px 10px;
  border: 1.5px solid rgba(214, 40, 40, 0.3);
  border-radius: var(--r-sm);
  font-family: var(--font-body), 'DM Sans', sans-serif;
  font-size: 0.76rem;
  color: var(--text2);
  background: var(--bg);
  outline: none;
  cursor: text;
}

.btn-copy-link {
  background: var(--oscuro);
  color: #fff;
  border: none;
  border-radius: var(--r-sm);
  padding: 8px 12px;
  font-family: var(--font-body), 'DM Sans', sans-serif;
  font-size: 0.72rem;
  font-weight: 700;
  cursor: pointer;
  transition: background 0.13s;
  white-space: nowrap;
}

.btn-copy-link:hover {
  background: var(--oscuro-2);
}

.btn-copy-link.copied {
  background: var(--verde-dark);
}

.btn-whatsapp {
  width: 100%;
  background: var(--verde);
  color: #fff;
  border: none;
  border-radius: var(--r-md);
  padding: 13px 20px;
  font-family: var(--font-display), 'Bebas Neue', sans-serif;
  font-size: 1.2rem;
  letter-spacing: 1.5px;
  cursor: pointer;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 10px;
  transition: background 0.13s, transform 0.1s;
  box-shadow: 0 4px 18px rgba(26, 107, 60, 0.3);
}

.btn-whatsapp:hover {
  background: var(--verde-dark);
  transform: scale(1.015);
}

.btn-whatsapp svg {
  width: 21px;
  height: 21px;
  fill: #fff;
  flex-shrink: 0;
}

.btn-whatsapp-text {
  display: flex;
  flex-direction: column;
  align-items: flex-start;
  gap: 1px;
}

.btn-wa-main {
  font-size: 1.2rem;
  line-height: 1;
}

.btn-wa-sub {
  font-size: 0.58rem;
  font-family: var(--font-body), 'DM Sans', sans-serif;
  font-weight: 600;
  letter-spacing: 1px;
  text-transform: uppercase;
  opacity: 0.72;
}

/* ══════════════════════════════════════════════════════════
   USER PANEL
   ══════════════════════════════════════════════════════════ */
.user-panel-body {
  flex: 1;
  overflow-y: auto;
  padding: 20px 20px 24px;
}

.auth-loading {
  text-align: center;
  padding: 40px 20px;
  color: var(--muted);
}

.auth-loading .spinner {
  width: 36px;
  height: 36px;
  border: 3px solid var(--border);
  border-top-color: var(--rojo);
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
  margin: 0 auto 12px;
}

@keyframes spin {
  to {
    transform: rotate(360deg);
  }
}

.auth-setup {
  display: flex;
  flex-direction: column;
  gap: 16px;
}

.auth-welcome {
  background: var(--bg);
  border: 1.5px solid var(--border);
  border-radius: var(--r-lg);
  padding: 18px;
  text-align: center;
}

.auth-welcome-emoji {
  font-size: 2.5rem;
  margin-bottom: 8px;
  display: block;
}

.auth-welcome h3 {
  font-size: 1rem;
  font-weight: 700;
  margin-bottom: 4px;
}

.auth-welcome p {
  font-size: 0.78rem;
  color: var(--text2);
  line-height: 1.5;
}

.form-group {
  display: flex;
  flex-direction: column;
  gap: 5px;
}

.form-label {
  font-size: 0.68rem;
  font-weight: 600;
  text-transform: uppercase;
  letter-spacing: 0.5px;
  color: var(--text2);
}

.btn-primary {
  background: var(--oscuro);
  color: #fff;
  border: none;
  border-radius: var(--r-md);
  padding: 12px 20px;
  font-family: var(--font-body), 'DM Sans', sans-serif;
  font-size: 0.9rem;
  font-weight: 700;
  cursor: pointer;
  transition: all 0.13s;
}

.btn-primary:hover {
  background: var(--oscuro-2);
  transform: translateY(-1px);
}

.btn-primary:disabled {
  opacity: 0.5;
  cursor: not-allowed;
  transform: none;
}

.btn-primary-full {
  width: 100%;
}

.auth-divider {
  display: flex;
  align-items: center;
  gap: 12px;
  color: var(--muted);
  font-size: 0.78rem;
}

.auth-divider::before,
.auth-divider::after {
  content: "";
  flex: 1;
  height: 1px;
  background: var(--border);
}

.btn-secondary-link {
  background: none;
  border: none;
  color: var(--rojo-dark);
  font-family: var(--font-body), 'DM Sans', sans-serif;
  font-size: 0.82rem;
  font-weight: 700;
  cursor: pointer;
  text-align: center;
  padding: 8px;
  transition: color 0.12s;
}

.btn-secondary-link:hover {
  color: var(--oscuro);
}

/* Guest panel */
.guest-panel {
  display: flex;
  flex-direction: column;
  gap: 20px;
}

.guest-alias-header {
  text-align: center;
  padding-bottom: 16px;
  border-bottom: 1.5px solid var(--border);
}

.guest-alias-eyebrow {
  font-size: 0.58rem;
  font-weight: 600;
  letter-spacing: 3px;
  text-transform: uppercase;
  color: var(--muted);
  display: block;
}

.guest-alias-name {
  font-family: var(--font-bebas), sans-serif;
  font-size: 2.2rem;
  color: var(--navy);
  letter-spacing: 1.5px;
  display: block;
  margin-top: 4px;
}

.btn-edit-alias {
  background: none;
  border: 1.5px solid var(--border);
  border-radius: var(--r-sm);
  padding: 4px 12px;
  font-family: var(--font-body), 'DM Sans', sans-serif;
  font-size: 0.68rem;
  font-weight: 600;
  color: var(--text2);
  cursor: pointer;
  margin-top: 8px;
  transition: all 0.12s;
}

.btn-edit-alias:hover {
  border-color: var(--oscuro);
  color: var(--oscuro);
}

.alias-edit-row {
  display: flex;
  flex-direction: column;
  gap: 8px;
}

.alias-edit-actions {
  display: flex;
  gap: 8px;
}

.btn-small-primary {
  flex: 1;
  background: var(--oscuro);
  color: #fff;
  border: none;
  border-radius: var(--r-sm);
  padding: 8px 12px;
  font-family: var(--font-body), 'DM Sans', sans-serif;
  font-size: 0.78rem;
  font-weight: 700;
  cursor: pointer;
  transition: background 0.12s;
}

.btn-small-primary:hover {
  background: var(--oscuro-2);
}

.btn-small-secondary {
  flex: 1;
  background: var(--bg2);
  color: var(--text2);
  border: 1.5px solid var(--border);
  border-radius: var(--r-sm);
  padding: 8px 12px;
  font-family: var(--font-body), 'DM Sans', sans-serif;
  font-size: 0.78rem;
  font-weight: 600;
  cursor: pointer;
  transition: all 0.12s;
}

.btn-small-secondary:hover {
  background: var(--bg3);
}

/* Pedidos section */
.pedidos-section {
  display: flex;
  flex-direction: column;
  gap: 8px;
}

.pedidos-section-title {
  font-size: 0.68rem;
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: 1.5px;
  color: var(--muted);
  margin-bottom: 4px;
}

.pedido-card {
  background: var(--bg);
  border: 1.5px solid var(--border);
  border-radius: var(--r-md);
  padding: 12px;
  transition: border-color 0.12s;
}

.pedido-card:hover {
  border-color: var(--border2);
}

.pedido-card-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 8px;
}

.pedido-card-date {
  font-size: 0.72rem;
  font-weight: 600;
  color: var(--text2);
}

.pedido-card-total {
  font-family: var(--font-display), 'Bebas Neue', sans-serif;
  font-size: 1.2rem;
  color: var(--texto);
}

.pedido-card-items {
  display: flex;
  flex-direction: column;
  gap: 3px;
  margin-bottom: 8px;
}

.pedido-card-item {
  display: flex;
  gap: 6px;
  font-size: 0.72rem;
}

.pedido-card-item-qty {
  font-weight: 800;
  color: var(--rojo-dark);
  min-width: 28px;
}

.pedido-card-item-name {
  flex: 1;
  font-weight: 600;
  color: var(--text);
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.pedido-card-item-more {
  color: var(--muted);
  font-weight: 600;
}

.pedidos-more {
  font-size: 0.74rem;
  font-weight: 600;
  color: var(--muted);
  text-align: center;
  padding: 4px 0;
}

.btn-create-account {
  width: 100%;
  background: var(--oscuro);
  color: #fff;
  border: none;
  border-radius: var(--r-md);
  padding: 12px 20px;
  font-family: var(--font-body), 'DM Sans', sans-serif;
  font-size: 0.88rem;
  font-weight: 700;
  cursor: pointer;
  transition: all 0.13s;
  text-align: center;
}

.btn-create-account:hover {
  background: var(--oscuro-2);
  transform: translateY(-1px);
}

.btn-clear-data {
  width: 100%;
  background: transparent;
  border: 1.5px solid var(--border2);
  color: var(--muted);
  border-radius: var(--r-sm);
  padding: 9px 16px;
  font-family: var(--font-body), 'DM Sans', sans-serif;
  font-size: 0.78rem;
  font-weight: 600;
  cursor: pointer;
  transition: all 0.13s;
}

.btn-clear-data:hover {
  border-color: var(--rojo);
  color: var(--rojo);
}

/* User panel (registered) */
.user-panel {
  display: flex;
  flex-direction: column;
  gap: 20px;
}

.user-header {
  text-align: center;
  padding-bottom: 16px;
  border-bottom: 1.5px solid var(--border);
}

.user-alias-eyebrow {
  font-size: 0.58rem;
  font-weight: 600;
  letter-spacing: 3px;
  text-transform: uppercase;
  color: var(--muted);
  display: block;
}

.user-alias-name {
  font-family: var(--font-bebas), sans-serif;
  font-size: 2.2rem;
  color: var(--navy);
  letter-spacing: 1.5px;
  display: block;
  margin-top: 4px;
}

.user-stats {
  font-size: 0.72rem;
  color: var(--text2);
  font-weight: 500;
  margin-top: 6px;
  display: block;
}

/* Listas section */
.listas-section {
  border-top: 1.5px solid var(--border);
  padding-top: 16px;
}

.listas-section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 8px;
}

.listas-section-title {
  font-size: 0.78rem;
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: 1px;
  color: var(--text2);
}

.btn-new-lista {
  background: var(--rojo-pale);
  border: 1.5px solid rgba(214, 40, 40, 0.35);
  color: var(--rojo-dark);
  border-radius: var(--r-sm);
  padding: 5px 12px;
  font-family: var(--font-body), 'DM Sans', sans-serif;
  font-size: 0.68rem;
  font-weight: 700;
  cursor: pointer;
  transition: all 0.12s;
}

.btn-new-lista:hover {
  background: rgba(214, 40, 40, 0.2);
}

/* Reorder & logout */
.btn-reorder {
  width: 100%;
  background: var(--ambar);
  color: #fff;
  border: none;
  border-radius: var(--r-md);
  padding: 12px 20px;
  font-family: var(--font-body), 'DM Sans', sans-serif;
  font-size: 0.88rem;
  font-weight: 700;
  cursor: pointer;
  transition: all 0.13s;
  text-align: center;
}

.btn-reorder:hover {
  background: var(--ambar);
  filter: brightness(1.1);
  transform: translateY(-1px);
}

.btn-reorder-small {
  background: none;
  border: 1.5px solid var(--border);
  border-radius: var(--r-sm);
  padding: 5px 10px;
  font-family: var(--font-body), 'DM Sans', sans-serif;
  font-size: 0.68rem;
  font-weight: 600;
  color: var(--rojo-dark);
  cursor: pointer;
  transition: all 0.12s;
  align-self: flex-start;
}

.btn-reorder-small:hover {
  background: var(--rojo-pale);
  border-color: rgba(214, 40, 40, 0.4);
}

.btn-logout {
  width: 100%;
  background: transparent;
  border: 1.5px solid var(--border2);
  color: var(--muted);
  border-radius: var(--r-sm);
  padding: 9px 16px;
  font-family: var(--font-body), 'DM Sans', sans-serif;
  font-size: 0.78rem;
  font-weight: 600;
  cursor: pointer;
  transition: all 0.13s;
}

.btn-logout:hover {
  border-color: var(--rojo);
  color: var(--rojo);
}

/* Auth form */
.auth-form-body {
  display: flex;
  flex-direction: column;
  gap: 14px;
}

.auth-error {
  background: var(--rojo-pale);
  border: 1.5px solid rgba(214, 40, 40, 0.25);
  border-radius: var(--r-sm);
  padding: 10px 12px;
  font-size: 0.78rem;
  color: var(--rojo);
  font-weight: 600;
}

.auth-switch {
  text-align: center;
  font-size: 0.78rem;
  color: var(--text2);
  padding-top: 8px;
}

.auth-link {
  background: none;
  border: none;
  color: var(--rojo-dark);
  font-family: var(--font-body), 'DM Sans', sans-serif;
  font-size: 0.78rem;
  font-weight: 700;
  cursor: pointer;
  padding: 0;
  transition: color 0.12s;
}

.auth-link:hover {
  color: var(--oscuro);
  text-decoration: underline;
}

/* ══════════════════════════════════════════════════════════
   BUSCADOR
   ══════════════════════════════════════════════════════════ */
.buscador-input-wrap {
  position: relative;
}

.buscador-input {
  width: 100%;
  padding: 11px 72px 11px 42px;
  border-radius: var(--r-md);
  border: 1.5px solid rgba(214, 40, 40, 0.18);
  background: rgba(255, 255, 255, 0.06);
  color: #fff;
  font-family: var(--font-body), 'DM Sans', sans-serif;
  font-size: 0.88rem;
  font-weight: 500;
  outline: none;
  transition: all 0.2s;
}

.buscador-input::placeholder {
  color: rgba(255, 255, 255, 0.3);
}

.buscador-input:focus {
  background: rgba(255, 255, 255, 0.1);
  border-color: rgba(214, 40, 40, 0.5);
  box-shadow: 0 0 0 3px rgba(214, 40, 40, 0.08);
}

.buscador-icon {
  position: absolute;
  left: 13px;
  top: 50%;
  transform: translateY(-50%);
  font-size: 0.88rem;
  color: rgba(255, 255, 255, 0.32);
  pointer-events: none;
}

.buscador-clear {
  position: absolute;
  right: 44px;
  top: 50%;
  transform: translateY(-50%);
  background: none;
  border: none;
  color: rgba(255, 255, 255, 0.5);
  font-size: 1.2rem;
  cursor: pointer;
  padding: 4px;
  line-height: 1;
  transition: color 0.12s;
}

.buscador-clear:hover {
  color: rgba(255, 255, 255, 0.9);
}

.buscador-voice {
  position: absolute;
  right: 10px;
  top: 50%;
  transform: translateY(-50%);
  background: rgba(214, 40, 40, 0.12);
  border: 1.5px solid rgba(214, 40, 40, 0.25);
  border-radius: 8px;
  width: 32px;
  height: 32px;
  display: flex;
  align-items: center;
  justify-content: center;
  cursor: pointer;
  font-size: 0.9rem;
  transition: all 0.15s;
}

.buscador-voice:hover {
  background: rgba(214, 40, 40, 0.22);
  border-color: rgba(214, 40, 40, 0.45);
}

.buscador-voice.listening {
  background: rgba(214, 40, 40, 0.2);
  border-color: rgba(214, 40, 40, 0.4);
  animation: voicePulse 1s ease-in-out infinite;
}

@keyframes voicePulse {

  0%,
  100% {
    opacity: 1;
  }

  50% {
    opacity: 0.6;
  }
}

.buscador-recent {
  position: absolute;
  top: calc(100% + 6px);
  left: 0;
  right: 0;
  background: var(--white);
  border: 1.5px solid var(--border);
  border-radius: var(--r-md);
  padding: 12px;
  box-shadow: var(--shadow-lg);
  z-index: 100;
}

.buscador-recent-label {
  font-size: 0.65rem;
  font-weight: 600;
  color: var(--muted);
  text-transform: uppercase;
  letter-spacing: 1px;
  margin-bottom: 8px;
}

.buscador-chips {
  display: flex;
  flex-wrap: wrap;
  gap: 6px;
}

.buscador-chip {
  background: var(--bg2);
  border: 1.5px solid var(--border);
  border-radius: 20px;
  padding: 5px 12px;
  font-family: var(--font-body), 'DM Sans', sans-serif;
  font-size: 0.72rem;
  font-weight: 600;
  color: var(--text2);
  cursor: pointer;
  transition: all 0.12s;
  white-space: nowrap;
}

.buscador-chip:hover {
  background: var(--bg3);
  border-color: var(--border2);
  color: var(--text);
}

/* ══════════════════════════════════════════════════════════
   DARK MODE (automatic)
   ══════════════════════════════════════════════════════════ */
@media (prefers-color-scheme: dark) {
  :root {
    --bg: #0F0C08;
    --bg2: #1A1410;
    --bg3: #2C2318;
    --white: #1F1A14;
    --texto: #F0EBE3;
    --tierra: #B8A99A;
    --border: #3D3226;
    --border-2: #4E4035;
    --border2: var(--border-2);
    /* alias legacy */
    --muted: #7A6F60;
    --text: var(--texto);
    --text2: var(--tierra);
  }
}